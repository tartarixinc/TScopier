{
  "name": "project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dev:backoffice": "npm --prefix apps/backoffice run dev",
    "build:backoffice": "npm --prefix apps/backoffice run build",
    "dev:docs": "npm --prefix apps/docs run dev",
    "build:docs": "npm --prefix apps/docs run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:edge": "deno test --allow-read --config supabase/functions/deno.json supabase/functions/_shared",
    "test:worker": "npm --prefix worker test",
    "test:worker:perf": "npm --prefix worker run test:perf",
    "test:load:stress": "npm --prefix worker run load:stress",
    "test:load:smoke": "npm --prefix worker run load:stress:smoke",
    "test:load:ws:live": "npm --prefix worker run load:ws:live",
    "test:regression": "playwright test --grep @regression",
    "test:all": "npm run test:worker && npm run test:worker:perf && npm run test:unit && npm run test:edge && npm run test:e2e"
  },
  "dependencies": {
    "@livechat/widget-react": "^1.4.0",
    "@supabase/supabase-js": "^2.105.3",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.6"
  }
}
