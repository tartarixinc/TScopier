# Frontend (Vite) — use `.env.local` for local secrets (gitignored). Vite loads it automatically.
# Worker — use `worker/.env.local` (loaded by worker/src/loadEnv.ts).
# In Netlify: Site configuration → Environment variables → add these exact names.
# Values are baked in at build time; redeploy after changing them.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional — use direct Supabase host for Realtime WebSocket when a custom auth domain
# (e.g. sso.tscopier.ai) causes intermittent browser WebSocket failures:
# VITE_SUPABASE_REALTIME_URL=https://YOUR_PROJECT_REF.supabase.co

# Marketing vs app hostnames (baked at build time — see docs/marketing-site.md)
VITE_APP_URL=https://app.tscopier.ai
VITE_MARKETING_URL=https://tscopier.ai
# VITE_DEV_SITE=marketing   # local preview of landing on localhost

# Optional — Stripe Checkout is hosted on stripe.com (no frontend publishable key required).
# Set STRIPE_SECRET_KEY and price IDs on Supabase Edge Functions (see supabase secrets).

# Optional
# VITE_BACKTEST_ENABLED=true
# VITE_GA_MEASUREMENT_ID=G-6TQBY0FKX3

# Help menu (header) — external links open in a new tab
# VITE_HELP_DOCS_URL=https://docs.tscopier.ai
# VITE_HELP_LIVE_CHAT_URL=
# VITE_HELP_WHATSAPP_URL=https://wa.me/1234567890
# VITE_HELP_TELEGRAM_URL=https://t.me/your_support_channel
# VITE_HELP_STATUS_URL=https://status.tscopier.ai

# Supabase Edge Function secrets (set via `supabase secrets set`, not in .env):
# RESEND_API_KEY=              — required for signup confirmation emails
# FMP_API_KEY=       — Market News + Economic Calendar

# FxSocket (Supabase Edge + worker) — see docs/fxsocket-integration.md
# FXSOCKET_API_KEY=fxs_live_...
# WORKER_PUBLIC_URL=https://your-worker.up.railway.app  — edge stream_ticket URLs

# Frontend WebSocket stream proxy (live dashboard metrics)
# VITE_WORKER_URL=https://your-worker.up.railway.app

# Worker (Railway / local worker/.env) — same FMP key for news-trading blackout filter:
# FMP_API_KEY=
