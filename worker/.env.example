SUPABASE_URL=https://sso.tscopier.ai
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN4a3Bjb3ZieWFmaWN2dGtwc2RvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Nzk4NjYwOCwiZXhwIjoyMDkzNTYyNjA4fQ.CWuwwOdDrUmmRuy-gUZRlQ-MeSl-Ba7Ei_FhPNvOdB4
TELEGRAM_API_ID=27790997
TELEGRAM_API_HASH=7a8174d5d6935d13f5b459cacc2e0cd7
PARSE_SIGNAL_URL=https://sso.tscopier.ai/functions/v1/parse-signal
PARSE_SIGNAL_KEY=your-service-role-key
# Max wait for parse-signal edge (ms). Lower = fail faster; cold starts may need 4000–6000.
# PARSE_SIGNAL_TIMEOUT_MS=6000
# How often tradeExecutor rescans missed parsed signals (ms). Default 3000.
# EXECUTOR_PARSED_SWEEP_MS=3000
# Max age for sweep/realtime replay of status=parsed rows (ms). Default 300000 (5 min).
# EXECUTOR_REPLAY_MAX_AGE_MS=300000
# Parallel handleSignal workers for queued sweep/realtime/mgmt (default 4). Live buy/sell on trade_entry bypass the queue.
# EXECUTOR_MAX_CONCURRENT_SIGNALS=4
# Split trade_entry/trade_mgmt: Realtime is OFF by default (each replica would duplicate trades). Listener uses TRADE_WORKER_URL push.
# Monolith/trade combined: default true. Set true on trade_entry only if you run a single replica and push is disabled.
# EXECUTOR_REALTIME_SIGNALS=false
# Cache Telegram listener lease gate per user on trade workers (ms). Default 8000.
# WORKER_LEASE_GATE_CACHE_MS=8000
# After worker restart: replay missed Telegram posts in background (default true).
# TELEGRAM_CATCHUP_ON_START=true
# Only parse/trade catch-up messages newer than this many minutes (default 20).
# TELEGRAM_CATCHUP_MAX_AGE_MINUTES=20
# Grace period on SIGTERM so the old instance releases the Telegram auth key before the new one connects.
# TELEGRAM_SHUTDOWN_DRAIN_MS=8000
# Catch-up parse slots (live messages use separate priority path).
# TELEGRAM_CATCHUP_PARSE_CONCURRENCY=2
# Pause catch-up briefly after each live message (ms).
# TELEGRAM_LIVE_PRIORITY_PAUSE_MS=500
# /health: mark stale if no Telegram event within this window (ms). Default 180000 (3 min).
# WORKER_HEALTH_STALE_MS=180000
# Process role: all | listener | trade | trade_entry | trade_mgmt | backtest
# WORKER_ROLE=all
# WORKER_SHARD_ID=0
# WORKER_SHARD_COUNT=1
# Split deploy: listener pushes parsed signals to trade (same WORKER_INTERNAL_TOKEN)
# TRADE_WORKER_URL=https://your-trade-entry.up.railway.app
# TRADE_MGMT_WORKER_URL=https://your-trade-mgmt.up.railway.app
# TRADE_SIGNAL_PUSH_ENABLED=true
# TRADE_SIGNAL_PUSH_TIMEOUT_MS=4000
# TRADE_SIGNAL_PUSH_MAX_ATTEMPTS=3
# TRADE_SIGNAL_PUSH_RETRY_BASE_MS=75
# TRADE_WORKER_SHARD_COUNT=4
# WORKER_INSTANCE_ID=optional-stable-id
# WORKER_SESSION_LEASE_TTL_MS=45000
# WORKER_LEASE_RENEW_INTERVAL_MS=20000
# Supabase Edge: optional dedicated backtest worker URL
# BACKTEST_WORKER_URL=https://your-backtest-worker.up.railway.app
# Min interval between session pings on OrderSend hot path (ms). Align with heartbeat (default matches BROKER_SESSION_HEARTBEAT_MS).
# BROKER_SESSION_PING_MIN_INTERVAL_MS=10000
# Proactive keepSessionAlive heartbeat interval (ms). Worker-side FxSocket session warming (default 15000).
# BROKER_SESSION_HEARTBEAT_MS=10000
# Parallel broker pings per heartbeat sweep (default 6).
# BROKER_HEARTBEAT_CONCURRENCY=6
# Consecutive keepSessionAlive failures before marking broker session down (default 4).
# BROKER_HEARTBEAT_FAILURES_BEFORE_DOWN=4
# Load symbol list/params on startup and each heartbeat tick (default true).
# EXECUTOR_PREWARM_SYMBOLS=true
# Reconnect sweep for active brokers (ms). Default 60000.
# BROKER_RECONNECT_INTERVAL_MS=60000
# BROKER_RECONNECT_IDLE_MS=120000
# Reconnect backoff cap + reset window (ms). Defaults: 300000 max, 1800000 reset.
# BROKER_RECONNECT_BACKOFF_MAX_MS=300000
# BROKER_RECONNECT_BACKOFF_RESET_MS=1800000
# Forced hard-reconnect sweep (error/recovering + auto_reconnect accounts, ms). Default 300000 (5 min).
# BROKER_HARD_RECONNECT_SWEEP_MS=300000
# Mark error after this long in recovering (ms). Default 1800000 (30 min).
# BROKER_RECOVERING_ERROR_AFTER_MS=1800000
# Min interval between worker connection_status DB writes per broker (ms). Default 60000.
# BROKER_CONNECTION_STATUS_MIN_WRITE_MS=60000
# Must match Supabase Edge broker-metatrader secret (always-on auto reconnect).
# BROKER_CREDENTIALS_ENCRYPTION_KEY=
# Cross-process ConnectEx lock (Postgres mt_server_connect_locks table). Defaults: wait 90s, poll 500ms, TTL 120s.
# MT_SERVER_CONNECT_LOCK_WAIT_MS=90000
# MT_SERVER_CONNECT_LOCK_POLL_MS=500
# MT_SERVER_CONNECT_LOCK_TTL_SEC=120

# Monitor idle backoff — active tick when work exists, longer sleep when idle (ms).
# VIRTUAL_PENDING_TICK_MS=1500
# VIRTUAL_PENDING_IDLE_MS=60000
# PARTIAL_TP_TICK_MS=1500
# PARTIAL_TP_IDLE_MS=60000
# AUTO_MANAGEMENT_TICK_MS=1500
# AUTO_MANAGEMENT_IDLE_MS=60000
# TRAILING_STOP_TICK_MS=1500
# TRAILING_STOP_IDLE_MS=60000
# CWE_CLOSE_TICK_MS=1500
# CWE_CLOSE_IDLE_MS=60000
# SIGNAL_ENTRY_PENDING_TICK_MS=1500
# SIGNAL_ENTRY_PENDING_IDLE_MS=60000
# BASKET_RECONCILE_TICK_MS=15000
# BASKET_RECONCILE_IDLE_MS=120000
# BASKET_RECONCILE_SWEEP_MS=180000
# BASKET_RECONCILE_SWEEP_BATCH=50
# EXECUTOR_PARSED_SWEEP_MS=3000
# EXECUTOR_SWEEP_IDLE_MS=60000

# trade_execution_logs batch retention (replaces per-insert prune trigger).
# TRADE_LOG_RETENTION_INTERVAL_MS=600000
# TRADE_LOG_RETENTION_KEEP=500

# Trade worker horizontal sharding (listener sets comma-separated URLs; index = hash(user_id) % N).
# TRADE_WORKER_SHARD_URLS=https://trade-shard-0.up.railway.app,https://trade-shard-1.up.railway.app
# Each trade shard service also sets WORKER_SHARD_ID / WORKER_SHARD_COUNT to match URL count.
# Management dispatch sharding (Adjust SL/TP, breakeven, close): comma-separated mgmt shard URLs,
# index = hash(user_id) % N. Without this, all management HTTP push goes to a single
# TRADE_MGMT_WORKER_URL — a bottleneck for management-heavy channels (e.g. GTMO VIP at scale).
# URL count must equal TRADE_WORKER_SHARD_COUNT.
# TRADE_MGMT_WORKER_SHARD_URLS=https://trade-mgmt-0.up.railway.app,https://trade-mgmt-1.up.railway.app

# Redis Streams queue (Upstash) — durable listener → trade dispatch (10k-ready)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# TRADE_SIGNAL_QUEUE_ENABLED=false
# TRADE_SIGNAL_QUEUE_ENTRY_STREAM=signals:entry
# TRADE_SIGNAL_QUEUE_MGMT_STREAM=signals:mgmt
# TRADE_SIGNAL_QUEUE_SHARD_COUNT=1
# Must match number of trade worker shards (use 1 for single trade worker).
# TRADE_SIGNAL_QUEUE_CONSUMER_CONCURRENCY=8
# Canary rollout: only these trade shards use queue (comma-separated). Omit for all shards.
# TRADE_SIGNAL_QUEUE_CANARY_SHARDS=0
# TRADE_SIGNAL_QUEUE_CONSUMER_BLOCK_MS=2000
# TRADE_SIGNAL_QUEUE_CLAIM_IDLE_MS=60000
# TRADE_SIGNAL_QUEUE_MAX_ATTEMPTS=5
# TRADE_SIGNAL_QUEUE_READ_COUNT=10
# TRADE_SIGNAL_QUEUE_RETRY_BASE_MS=250
# When queue enqueue fails, fall back to HTTP push (default true during cutover).
# TRADE_SIGNAL_PUSH_FALLBACK_ON_QUEUE_FAIL=true
# After stable queue SLO: set TRADE_SIGNAL_PUSH_ENABLED=false to disable HTTP push globally.
# Pre-warm /Symbols + /SymbolParams on trade worker start (default true).
# EXECUTOR_PREWARM_SYMBOLS=true
# Inline parse in listener (default true). false = edge parse-signal HTTP fallback.
# LISTENER_INLINE_PARSE=true
# gramjs listener only — set telethon on Python telegram-listener service instead.
# LISTENER_ENGINE=gramjs
# Trade HTTP dispatch: await OrderSend before ACK (default true on split deploy).
# TRADE_DISPATCH_AWAIT_DEFAULT=true
# Channel keywords/lexicon cache TTL for inline parse (ms). Default 300000 (5 min).
# CHANNEL_PARSE_CACHE_TTL_MS=300000
# OpenAI for modification/management messages (replies, move SL, message revisions).
# Stretched spellings (e.g. breakevennn, noowww) are normalized before deterministic parse.
# OPENAI_API_KEY is an optional fallback when deterministic parse misses or confidence is low.
# Required on the LISTENER worker (Railway WORKER_ROLE=listener) for AI-assisted revisions.
# Without it, structured entry edits still reconcile via deterministic re-parse.
# OPENAI_API_KEY=
# Re-fetch bare teaser entries (e.g. "Gold buy now") after channel adds SL/TP via edit.
# ENTRY_MESSAGE_SETTLE_MS=10000
# Multi-shot settle polls (ms, comma-separated). Default: ENTRY_MESSAGE_SETTLE_MS then 3x (max 30s).
# ENTRY_MESSAGE_SETTLE_DELAYS_MS=10000,30000
# Cron backup: WORKER_URL (or TELEGRAM_LISTENER_URL) + WORKER_INTERNAL_TOKEN on edge signal-reconcile-sweep
# AI_MODIFICATION_PARSE_ENABLED=true
# AI_MODIFICATION_PARSE_TIMEOUT_MS=3500
# AI_MODIFICATION_PARSE_MODEL=gpt-4o-mini
# Optional: OpenAI fallback when deterministic entry parse fails (default false).
# Requires OPENAI_API_KEY on the same listener worker — enabling without the key has no effect.
# AI_ENTRY_PARSE_ENABLED=false
# AI_ENTRY_PARSE_TIMEOUT_MS=4000
# AI_ENTRY_PARSE_MODEL=gpt-4o-mini
# Signal ↔ Telegram text reconciliation (edited messages).
# SIGNAL_RECONCILE_SWEEP_MS=60000
# SIGNAL_RECONCILE_WINDOW_MS=21600000
# SIGNAL_RECONCILE_MAX_SIGNALS=100
# SIGNAL_RECONCILE_POLL_HOOK_WINDOW_MS=7200000
# SIGNAL_RECONCILE_POLL_HOOK_MAX_SIGNALS=30
# Block live entry during news blackout before OrderSend (default false; post-fill audit only).
# EXECUTOR_NEWS_BLACKOUT_PRE_FILL=false
# FxSocket MT5 API — platform key from https://fxsocket.com (see docs/fxsocket-integration.md)
FXSOCKET_API_KEY=fxs_live_...
# FXSOCKET_BASE_URL=https://api.fxsocket.com
# FXSOCKET_HTTP_CONNECTIONS=128
# Public worker URL for browser WebSocket streams (stream_ticket edge action)
# WORKER_PUBLIC_URL=https://your-worker.up.railway.app

# Internal HTTP server consumed by the supabase telegram-auth edge function
# Generate a long random string (e.g. `openssl rand -hex 32`).
# WORKER_URL must be the public Railway URL (https://your-app.up.railway.app) — scheme required for fetch; host-only is auto-fixed in telegram-auth.
WORKER_INTERNAL_TOKEN=replace-with-long-random-secret
WORKER_PORT=8080

# Multi-trade merge: set true to use legacy reply/thread linking for SL/TP posts (default false = latest open basket).
# WORKER_LEGACY_MERGE_LINKING=false
# Basket SL/TP refresh: rounds to wait for late trade rows/tickets before giving up (default 8; live mgmt fast path uses 2).
# BASKET_REFRESH_STRAGGLER_ROUNDS=8
# Inter-leg gap for sequential basket modifies (default 50ms; live mgmt fast path uses 0).
# BASKET_LEG_MODIFY_GAP_MS=50
# Management leg parallelism for CWE / close / SL modify on live Telegram path (default 6, max 12).
# MGMT_LEG_CONCURRENCY=6
# Max concurrent trade ops (OrderSend/Modify/Close) per broker account. An MT terminal
# executes orders serially; too many in-flight at one terminal makes the bridge time out.
# Default 3, capped at 8. Lower (2) if you still see "OrderModify timed out" under bursts.
# MT_PER_ACCOUNT_TRADE_CONCURRENCY=3
# Canonical channel SL apply (live mgmt + diagnostics). Default on; set false to use legacy path.
# MGMT_USE_CHANNEL_STOP_APPLY=true
# Post-close verify sleep ms on live fast tier (default 0); sweeps/reconcile keep 400ms poll.
# MGMT_CLOSE_VERIFY_MS=0
# Redis mgmt stream consumer block ms (default 150; was 500).
# TRADE_SIGNAL_QUEUE_MGMT_CONSUMER_BLOCK_MS=150
# Listener HTTP push timeout for mgmt signals (default 5000ms fallback when queue disabled).
# TRADE_SIGNAL_PUSH_TIMEOUT_MS=5000
# Basket reconcile monitor (failed merge retries): tick interval ms, max attempts, backoff base ms.
# BASKET_RECONCILE_TICK_MS=15000
# BASKET_RECONCILE_MAX_ATTEMPTS=48
# BASKET_RECONCILE_BACKOFF_MS=15000

# Backtest market data uses FXSOCKET_API_KEY on Supabase Edge (linked broker terminal).
# No separate market-data key is required on the worker.

# One-off diagnostics on Railway (run inside worker service shell after deploy):
#   npm run build
#   DRY_RUN=true SIGNAL_ID=<uuid> SINCE_ISO=2026-06-17T11:08:00Z npm run rebalance-open-baskets
#   DRY_RUN=true SIGNAL_ID=<uuid> SINCE_ISO=2026-06-17T11:08:00Z SL_ONLY=true npm run push-signal-stops
# Requires: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, FXSOCKET_API_KEY (omit DRY_RUN to execute).
