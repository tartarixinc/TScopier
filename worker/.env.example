PARSE_SIGNAL_URL=https://sxkpcovbyaficvtkpsdo.supabase.co/functions/v1/parse-signal
PARSE_SIGNAL_KEY=your-service-role-key
# Max wait for parse-signal edge (ms). Lower = fail faster; cold starts may need 4000–6000.
# PARSE_SIGNAL_TIMEOUT_MS=6000
# How often tradeExecutor rescans missed parsed signals (ms). Default 3000.
# EXECUTOR_PARSED_SWEEP_MS=3000
# Min interval between /ConnectByToken keep-alive per broker (ms). Default 25000.
# BROKER_SESSION_PING_MIN_INTERVAL_MS=25000
# MT4/MT5 REST (mt4api.dev) — Basic Auth; platform-specific hosts. See docs/mt4api-endpoint-map.md
# Use PLAIN TEXT from support (the app base64-encodes user:password for the Authorization header).
MT4API_BASIC_USER=your-mt4api-username
MT4API_BASIC_PASSWORD=your-mt4api-password
# Optional alternatives (do not set both styles at once):
# MT4API_BASIC_TOKEN=c2N1bHB0dXJlNDEyODp...   # pre-encoded base64(user:password) only
# MT4API_AUTHORIZATION=Basic c2N1bHB0dXJlNDEyODp...  # full Authorization header value
# No trailing slash or parentheses — exact host only:
MT4API_MT5_BASE_URL=https://mt5.mt4api.dev
MT4API_MT4_BASE_URL=https://mt4.mt4api.dev
# Optional: reconnect all cached broker sessions on worker start (ConnectByToken)
# MT4API_RECONNECT_ON_START=true

# Internal HTTP server consumed by the supabase telegram-auth edge function
# Generate a long random string (e.g. `openssl rand -hex 32`).
# WORKER_URL must be the public Railway URL (https://your-app.up.railway.app) — scheme required for fetch; host-only is auto-fixed in telegram-auth.
WORKER_INTERNAL_TOKEN=replace-with-long-random-secret
WORKER_PORT=8080

# Multi-trade merge: set true to use legacy reply/thread linking for SL/TP posts (default false = latest open basket).
# WORKER_LEGACY_MERGE_LINKING=false
# Basket SL/TP refresh: rounds to wait for late trade rows/tickets before giving up (default 8).
# BASKET_REFRESH_STRAGGLER_ROUNDS=8
# Basket reconcile monitor (failed merge retries): tick interval ms, max attempts, backoff base ms.
# BASKET_RECONCILE_TICK_MS=15000
# BASKET_RECONCILE_MAX_ATTEMPTS=48
# BASKET_RECONCILE_BACKOFF_MS=15000

# Massive.com market data for signal backtesting (also set in Supabase Edge secrets)
MASSIVE_API_KEY=zVos6hMc6qlnKXXNJZwKYqTMAyqNx_jC
MASSIVE_API_BASE_URL=https://api.massive.com
# Match your Massive plan (starter/free is often 5/min — set in Supabase Edge secrets too)
MASSIVE_CALLS_PER_MINUTE=5

